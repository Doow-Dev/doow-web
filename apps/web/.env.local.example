# PostHog Analytics Configuration
# Copy this file to .env.local and add your actual values

# Required: Your PostHog Project API Key
# Found in PostHog Settings > Project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_V6I6bimhG3mzVQpzbmFtiqSaoLuFuTvrASUDNYNJXnC

# Optional: Custom PostHog host (defaults to https://us.i.posthog.com)
# Your API host from PostHog Settings
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Asset host used by the typed blob asset manifest
NEXT_PUBLIC_BLOB_BASE_URL=https://landingpageassests.blob.core.windows.net/images

# Canonical public marketing/blog host
NEXT_PUBLIC_SITE_URL=https://www.doow.co

# Main Doow app host used by same-tab login and signup CTAs
NEXT_PUBLIC_DOOW_APP_BASE_URL=https://dev.doow.co

# Server-only Doow API configuration
DOOW_API_BASE_URL=
CATALOG_ADMIN_KEY=
X_ADMIN_SECRET=
