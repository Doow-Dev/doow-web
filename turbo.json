{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "BLOG_LIVE",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_BLOB_BASE_URL",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_DOCS_SITE_URL",
    "DOCS_SEARCH_APP_ID",
    "DOCS_SEARCH_API_KEY",
    "DOCS_SEARCH_INDEX"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "check:content": {
      "outputs": []
    },
    "check:boundaries": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
