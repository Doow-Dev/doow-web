  Grouped response (?grouped=true)

  {
    "data": {
      "Accounting & Bookkeeping": [ { ...integration }, { ...integration } ],
      "AI & LLM Providers": [ { ...integration } ],
      "HR & People": [ { ...integration } ]
    },
    "total": 41,
    "take": 10,
    "skip": 0,
    "nextCursor": "clx1abc..."
  }

