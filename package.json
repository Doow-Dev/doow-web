{
  "name": "doow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "eslint-plugin-react-hooks": "7.0.1"
    }
  },
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @doow/web dev",
    "dev:docs": "pnpm --filter @doow/docs dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @doow/web build",
    "build:docs": "pnpm --filter @doow/docs build",
    "start": "pnpm --filter @doow/web start",
    "analyze": "pnpm --filter @doow/web analyze",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check:content": "turbo run check:content",
    "check:boundaries": "node tools/check-boundaries.mjs",
    "check:deployment": "node tools/check-deployment-config.mjs",
    "verify": "pnpm check:boundaries && pnpm check:deployment && pnpm lint && pnpm typecheck && pnpm test && pnpm check:content && pnpm build",
    "check:blog:s2": "pnpm --filter @doow/web check:blog:s2",
    "check:blog:s4": "pnpm --filter @doow/web check:blog:s4",
    "check:blog:s5": "pnpm --filter @doow/web check:blog:s5",
    "check:blog:s6": "pnpm --filter @doow/web check:blog:s6",
    "check:blog:s8": "pnpm --filter @doow/web check:blog:s8",
    "check:blog:s9": "pnpm --filter @doow/web check:blog:s9",
    "check:blog:s11": "pnpm --filter @doow/web check:blog:s11",
    "check:blog:launch": "pnpm --filter @doow/web check:blog:launch",
    "test:unit": "pnpm --filter @doow/web test:unit",
    "test:a11y": "pnpm --filter @doow/web test:a11y",
    "test:seo": "pnpm --filter @doow/web test:seo",
    "test:lighthouse": "pnpm --filter @doow/web test:lighthouse",
    "test:production": "pnpm --filter @doow/web test:production",
    "lighthouse:desktop": "pnpm --filter @doow/web lighthouse:desktop",
    "lighthouse:mobile": "pnpm --filter @doow/web lighthouse:mobile",
    "test:e2e": "pnpm --filter @doow/web test:e2e",
    "test:e2e:headed": "pnpm --filter @doow/web test:e2e:headed",
    "test:e2e:install": "pnpm --filter @doow/web test:e2e:install"
  },
  "devDependencies": {
    "turbo": "2.9.10"
  }
}
