{
  "name": "doow-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-standalone.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "analyze": "set ANALYZE=true&& next build",
    "check:blog:s2": "bash scripts/check-blog/s2.sh",
    "check:blog:s4": "bash scripts/check-blog/s4.sh",
    "check:blog:s5": "bash scripts/check-blog/s5.sh",
    "check:blog:s6": "bash scripts/check-blog/s6.sh",
    "check:blog:s8": "bash scripts/check-blog/s8.sh",
    "check:blog:s9": "bash scripts/check-blog/s9.sh",
    "check:blog:s11": "bash scripts/check-blog/s11.sh",
    "check:blog:launch": "bash scripts/check-blog/launch.sh",
    "test:unit": "node tests/unit/integrations.test.mjs && node tests/unit/integration-catalog.test.mjs && node tests/unit/alternative-apps.test.mjs && node tests/unit/blog-live-policy.test.mjs",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:seo": "playwright test tests/e2e/seo-production.spec.ts",
    "lighthouse:desktop": "lhci autorun --config=./lighthouserc.desktop.cjs",
    "lighthouse:mobile": "lhci autorun --config=./lighthouserc.cjs",
    "test:lighthouse": "start-server-and-test start http://localhost:3000 \"npm run lighthouse:mobile && npm run lighthouse:desktop\"",
    "test:production": "npm run lint && npm run typecheck && npm run test:unit && npm run build && npm run test:a11y && npm run test:seo && npm run test:lighthouse"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "feed": "^5.2.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "mdast-util-to-string": "^4.0.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-mdx-remote": "^6.0.0",
    "posthog-js": "^1.368.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.9",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
